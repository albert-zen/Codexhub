{
  "name": "@codexhub/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dogfood:smoke": "pnpm --filter @codexhub/core build && tsc -p tsconfig.json && node dist/dogfood-smoke.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@codexhub/core": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.6",
    "tsx": "^4.21.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "vitest": "^4.0.15"
  }
}
